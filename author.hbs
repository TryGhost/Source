{{!< default}}
{{!-- cyber/verso · author archive

     Header: breadcrumb + full bio block (avatar, name, blurb,
     mono link row, location, post count). Then a grid of
     cv-post-card and the cv-pagination partial. `posts` is
     auto-filtered to the current author by Ghost.
--}}

<main class="cv-archive" id="cv-main">

    {{#author}}
        <header class="cv-archive-header cv-author-archive-header">

            <nav class="cv-archive-breadcrumb" aria-label="Breadcrumb">
                <ol>
                    <li><a href="{{@site.url}}">{{t "home"}}</a></li>
                    <li><span class="cv-slash" aria-hidden="true">/</span> <span>{{t "author"}}</span></li>
                    <li><span class="cv-slash" aria-hidden="true">/</span> <span class="cv-archive-breadcrumb-current" aria-current="page">{{slug}}</span></li>
                </ol>
            </nav>

            <div class="cv-author-bio-inner">

                {{#if profile_image}}
                    <img class="cv-author-bio-avatar cv-author-bio-avatar--lg" src="{{img_url profile_image size="m"}}" alt="{{name}}">
                {{/if}}

                <div class="cv-author-bio-text">

                    <h1 class="cv-archive-title">{{name}}</h1>

                    {{#if bio}}
                        <p class="cv-author-bio-blurb">{{bio}}</p>
                    {{/if}}

                    <p class="cv-author-bio-links">
                        {{#if website}}<a href="{{website}}" rel="me">site</a>{{/if}}
                        {{#if twitter}}<a href="{{social_url type="twitter"}}" rel="me">x</a>{{/if}}
                        {{#if bluesky}}<a href="{{social_url type="bluesky"}}" rel="me">bluesky</a>{{/if}}
                        {{#if mastodon}}<a href="{{social_url type="mastodon"}}" rel="me">mastodon</a>{{/if}}
                        {{#if linkedin}}<a href="{{social_url type="linkedin"}}" rel="me">linkedin</a>{{/if}}
                        {{#if threads}}<a href="{{social_url type="threads"}}" rel="me">threads</a>{{/if}}
                        {{#if facebook}}<a href="{{social_url type="facebook"}}" rel="me">facebook</a>{{/if}}
                        {{#if instagram}}<a href="{{social_url type="instagram"}}" rel="me">instagram</a>{{/if}}
                        {{#if tiktok}}<a href="{{social_url type="tiktok"}}" rel="me">tiktok</a>{{/if}}
                        {{#if youtube}}<a href="{{social_url type="youtube"}}" rel="me">youtube</a>{{/if}}
                        <a href="{{@site.url}}/rss/">rss</a>
                    </p>

                    {{#if location}}
                        <p class="cv-author-bio-location">{{location}}</p>
                    {{/if}}

                    {{!-- count.posts is not auto-included on the author taxonomy
                         context; ../pagination.total walks up to the route context
                         where Ghost has resolved the paginated posts collection. --}}
                    <p class="cv-archive-count">
                        {{plural ../pagination.total empty=(t "no posts yet") singular=(t "1 post") plural=(t "% posts")}}
                    </p>

                </div>
            </div>

        </header>
    {{/author}}

    {{#if posts}}
        <ul class="cv-recent-grid cv-archive-grid">
            {{#foreach posts}}
                <li>{{> "cv-post-card"}}</li>
            {{/foreach}}
        </ul>
    {{/if}}

</main>

{{> "cv-pagination"}}
