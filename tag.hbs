{{!< default}}
{{!-- cyber/verso · tag archive

     Header: breadcrumb (mono) + tag name (serif) + optional
     description + post count. Then a grid of cv-post-card and the
     cv-pagination partial. The `posts` collection is auto-filtered
     by Ghost to the current tag and paginated.
--}}

<main class="cv-archive" id="cv-main">

    {{#tag}}
        <header class="cv-archive-header">

            <nav class="cv-archive-breadcrumb" aria-label="Breadcrumb">
                <ol>
                    <li><a href="{{@site.url}}">{{t "home"}}</a></li>
                    <li><span class="cv-slash" aria-hidden="true">/</span> <span>{{t "tag"}}</span></li>
                    <li><span class="cv-slash" aria-hidden="true">/</span> <span class="cv-archive-breadcrumb-current" aria-current="page">{{slug}}</span></li>
                </ol>
            </nav>

            <h1 class="cv-archive-title">{{name}}</h1>

            {{#if description}}
                <p class="cv-archive-description">{{description}}</p>
            {{/if}}

        </header>
    {{/tag}}

    {{!-- count.posts is not auto-included on the tag taxonomy context;
         pagination.total (resolved on the outer route context) is what
         we have available. --}}
    <p class="cv-archive-count">
        {{plural pagination.total empty=(t "no posts yet") singular=(t "1 post") plural=(t "% posts")}}
    </p>

    {{#if posts}}
        <ul class="cv-recent-grid cv-archive-grid">
            {{#foreach posts}}
                <li>{{> "cv-post-card"}}</li>
            {{/foreach}}
        </ul>
    {{else}}
        <p class="cv-archive-empty">{{t "no posts yet under this tag."}}</p>
    {{/if}}

</main>

{{> "cv-pagination"}}
