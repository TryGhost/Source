{{!< default}}
{{!-- cyber/verso · tag archive

     Header: breadcrumb (mono) + tag name (serif) + optional
     description + post count. Then a grid of cv-post-card and the
     cv-pagination partial. The `posts` collection is auto-filtered
     by Ghost to the current tag and paginated.
--}}

<main class="cv-archive">

    {{#tag}}
        <header class="cv-archive-header">

            <p class="cv-archive-breadcrumb">
                <a href="{{@site.url}}">home</a>
                <span class="cv-slash" aria-hidden="true">/</span>
                <span>tag</span>
                <span class="cv-slash" aria-hidden="true">/</span>
                <span class="cv-archive-breadcrumb-current">{{slug}}</span>
            </p>

            <h1 class="cv-archive-title">{{name}}</h1>

            {{#if description}}
                <p class="cv-archive-description">{{description}}</p>
            {{/if}}

            <p class="cv-archive-count">
                {{plural count.posts empty='no posts yet' singular='1 post' plural='% posts'}}
            </p>

        </header>
    {{/tag}}

    {{#if posts}}
        <ul class="cv-recent-grid cv-archive-grid">
            {{#foreach posts}}
                <li>{{> "cv-post-card"}}</li>
            {{/foreach}}
        </ul>
    {{else}}
        <p class="cv-archive-empty">no posts yet under this tag.</p>
    {{/if}}

</main>

{{> "cv-pagination"}}
